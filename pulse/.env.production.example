# ── The Daily Pulse — production environment ──
# Copy to `.env` on the server and fill in the blanks.

APP_NAME="TheTrueDefender"
APP_ENV=production
APP_KEY=                        # generate: docker compose run --rm app php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Caddy edge (automatic HTTPS). For an IP-only test with no domain, set APP_DOMAIN=:80
APP_DOMAIN=yourdomain.com
TLS_EMAIL=you@yourdomain.com

APP_LOCALE=en
LOG_CHANNEL=stack
LOG_LEVEL=warning

# ── Database (PostgreSQL container) ──
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=dailypulse
DB_USERNAME=dailypulse
DB_PASSWORD=change-this-strong-password

# ── Redis (cache / queue / sessions) ──
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── Mail (set to your provider; used for contact/newsletter later) ──
MAIL_MAILER=log
MAIL_FROM_ADDRESS="news@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Web Push (VAPID) ──
# Reuse the dev keys or regenerate: docker compose run --rm app php -r "require 'vendor/autoload.php'; print_r(Minishlink\WebPush\VAPID::createVapidKeys());"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@yourdomain.com

# ── AI news rewriter (OpenAI) ──
OPENAI_API_KEY=
PULSE_AI_MODEL=gpt-4o-mini

# ── Google AdSense (fill after approval) ──
ADSENSE_CLIENT=
ADSENSE_SLOT_ARTICLE=
ADSENSE_SLOT_DISPLAY=

# ── Stripe payments (optional — blank = cash-on-delivery checkout) ──
# Prefer setting these in Admin → AI & Ads Settings. Webhook endpoint: /stripe/webhook
STRIPE_KEY=            # publishable key pk_live_… / pk_test_…
STRIPE_SECRET=        # secret key sk_live_… / sk_test_…
STRIPE_WEBHOOK_SECRET=

# ── Google Search Console — real ranking data (optional) ──
# Prefer setting these in Admin → AI & Ads Settings. See DEPLOY.md §10.
GSC_PROPERTY=                 # sc-domain:yourdomain.com  or  https://yourdomain.com/
GSC_SERVICE_ACCOUNT_JSON=     # full service-account JSON key (single line)
