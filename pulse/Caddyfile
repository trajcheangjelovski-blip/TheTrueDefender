# Automatic HTTPS reverse proxy for The Daily Pulse.
# APP_DOMAIN / TLS_EMAIL come from the environment (see docker-compose.yml).
# For a quick IP-only test with no domain, set APP_DOMAIN=:80 in .env.
{$APP_DOMAIN} {
	root * /var/www/html/public
	encode zstd gzip

	# Hand .php requests to the php-fpm "app" service; serve everything else as files.
	php_fastcgi app:9000
	file_server

	# Let's Encrypt certificate (omit/ignored when APP_DOMAIN is :80)
	tls {$TLS_EMAIL}

	header {
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Long cache for versioned assets (CSS/JS are cache-busted with ?v=filemtime).
	@immutable path *.css *.js *.woff2 *.woff *.ttf *.svg *.ico
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	# Media: cache 30 days (filenames are stable/unique).
	@media path /storage/* *.png *.jpg *.jpeg *.webp *.gif
	header @media Cache-Control "public, max-age=2592000"

	# Don't serve dotfiles or sensitive paths.
	@forbidden path /.env* /storage/*.key
	respond @forbidden 404
}

# Redirect www → apex (canonical URL). Caddy auto-provisions HTTPS for both.
# (Only relevant when APP_DOMAIN is a real hostname, not the :80 IP-test mode.)
www.{$APP_DOMAIN} {
	tls {$TLS_EMAIL}
	redir https://{$APP_DOMAIN}{uri} permanent
}
